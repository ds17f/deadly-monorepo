# Main site — SITE_ADDRESS set per environment in .env
{$SITE_ADDRESS} {
	handle /api/* {
		reverse_proxy api:3001
	}

	handle /ws/* {
		reverse_proxy api:3001
	}

	# Serve AASA with correct Content-Type for iOS Universal Links
	handle /.well-known/apple-app-site-association {
		root * /srv/ui
		header Content-Type application/json
		file_server
	}

	handle {
		root * /srv/ui
		file_server
		try_files {path} {path}/index.html {path}.html /index.html
	}
}

# Share site — SHARE_ADDRESS set per environment in .env
{$SHARE_ADDRESS} {
	# Serve AASA with correct Content-Type for iOS Universal Links
	handle /.well-known/apple-app-site-association {
		root * /srv/share
		header Content-Type application/json
		file_server
	}

	# Rewrite /shows/{id}/recording/{rid} to /shows/{id}/ so the
	# show's OG-tagged index.html is served for recording share links
	@recording path_regexp recording ^/shows/([^/]+)/recording/.*$
	rewrite @recording /shows/{re.recording.1}/

	handle {
		root * /srv/share
		file_server
		try_files {path} {path}/index.html /index.html
	}
}
