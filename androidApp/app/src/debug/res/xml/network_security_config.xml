<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug builds:
         - allow cleartext HTTP (hermetic test server, local dev servers)
         - trust user-installed CAs (mitmproxy capture; release builds unaffected) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
