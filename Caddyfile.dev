:80 {
	# Inject the analytics key server-side so the browser never holds the
	# secret. Must precede /api/* (Caddy matches handle blocks in order).
	handle /api/analytics {
		reverse_proxy api:3001 {
			header_up X-Analytics-Key {$ANALYTICS_API_KEY}
		}
	}

	handle /api/* {
		reverse_proxy api:3001
	}

	handle /ws/* {
		reverse_proxy api:3001
	}

	handle {
		root * /srv/ui
		file_server
		try_files {path} {path}/index.html {path}.html /index.html
	}
}

:8081 {
	# Serve AASA with correct Content-Type for iOS Universal Links
	handle /.well-known/apple-app-site-association {
		root * /srv/share
		header Content-Type application/json
		file_server
	}

	handle {
		root * /srv/share
		file_server
		try_files {path} {path}/index.html /index.html
	}
}
