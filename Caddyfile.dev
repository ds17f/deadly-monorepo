:80 {
	handle /api/* {
		reverse_proxy api:3001
	}

	handle /ws/* {
		reverse_proxy api:3001
	}

	handle /shows/* {
		root * /srv/ui
		file_server
		try_files {path} {path}/index.html /shows/_/index.html
	}

	handle /artists/* {
		root * /srv/ui
		file_server
		try_files {path} {path}/index.html /artists/_/index.html
	}

	handle /show/* {
		root * /srv/ui
		file_server
		try_files {path} {path}/index.html /show/_/index.html
	}

	handle {
		root * /srv/ui
		file_server
		try_files {path} {path}/index.html {path}.html /index.html
	}
}

:8081 {
	# Serve AASA with correct Content-Type for iOS Universal Links
	handle /.well-known/apple-app-site-association {
		root * /srv/share
		header Content-Type application/json
		file_server
	}

	handle {
		root * /srv/share
		file_server
		try_files {path} {path}/index.html /index.html
	}
}
