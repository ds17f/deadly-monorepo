# API Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=*

# Database
USERS_DB_PATH=./data/users.db

# Auth (Auth.js v5)
AUTH_SECRET=          # 32+ char random string: openssl rand -base64 32
AUTH_URL=https://beta.thedeadly.app

# Google OAuth
GOOGLE_CLIENT_ID=                  # Web client (also used as Android serverClientId)
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=              # iOS OAuth client ID
GOOGLE_ANDROID_CLIENT_ID=          # Set to GOOGLE_CLIENT_ID value (Android uses web client as audience)

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# setlist.fm API (free key from https://api.setlist.fm/)
SETLISTFM_API_KEY=

# Analytics
ANALYTICS_API_KEY=             # Shared secret for mobile clients: node -e "console.log(crypto.randomUUID())"
ANALYTICS_DB_PATH=./data/analytics.db
ANALYTICS_RAW_RETENTION_DAYS=  # Optional: prune raw events older than N days
